# ============================================================================
# .env.local.example — SOLO NOMBRES de variables, SIN valores reales.
# Copiá este archivo a .env.local y completá los valores (NO commitees .env.local).
# Lo más rápido si el repo está linkeado a Vercel:  vercel env pull .env.local
# ============================================================================

# ── Requeridas para arrancar /admin en local ────────────────────────────────

# Clerk (autenticación). Sin la publishable key, providers.tsx no monta
# <ClerkProvider> y /admin crashea con "useAuth ... within <ClerkProvider/>".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (proyecto vutjuyjizvmqrqnlyujp, schema legal)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Notificaciones internas (Telegram) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_CHAT_ID=

# ── Módulo de audiencias / recordatorios (Fases 3+) ─────────────────────────
# Microsoft Graph (envío de correo). La app de Azure la registra Amanda.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER=asistente@papeleo.legal

# Modo prueba / cron de recordatorios
RECORDATORIOS_TEST_EMAIL=
CRON_SECRET=
APP_BASE_URL=https://amandasantizo.com
